# Copy to .env locally (never commit secrets). On Vercel: Project Settings → Environment Variables.

# --- GitHub (required for APIs + data scripts) ---
GITHUB_TOKEN=
# Or use GH_TOKEN for CLI/scripts
GITHUB_ORG=your-org
GITHUB_USER=your-username
# Comma-separated GitHub logins counted as "human" in author split (optional; if empty, all non-bot authors = human)
GITHUB_HUMAN_AUTHORS=

# --- Vercel API (optional, /api/infra-stats) ---
VERCEL_API_KEY=
# Team ID if projects are under a team; leave empty for personal/hobby
VERCEL_TEAM_ID=

# --- Supabase (optional, /api/infra-stats) ---
SUPABASE_ACCESS_TOKEN=
# JSON array of { id, name, host } — or leave empty to skip Supabase block
# SUPABASE_PROJECTS=[{"id":"abc","name":"My App","host":"db.abc.supabase.co"}]

# --- Health checks (optional, /api/health-check) ---
# JSON array of { name, url } — HEAD requests
# HEALTH_TARGETS=[{"name":"API","url":"https://api.example.com/health"}]

# --- Asset generation (scripts/generate-assets.mjs) ---
APP_NAME=Workload-Portfolio
APP_DOMAIN=your-app.vercel.app
APP_REPO_LABEL=your-org/workload-portfolio

# --- Local dependency scan (optional) ---
# SCAN_ROOT=/path/to/parent/folder/with/cloned/repos
