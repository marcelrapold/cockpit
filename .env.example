# Copy to .env locally (never commit secrets). On Vercel: Project Settings → Environment Variables.

# --- GitHub (required for APIs + data scripts) ---
GITHUB_TOKEN=
GITHUB_USER=muraschal
# Comma-separated orgs to track (repos, issues, PRs across all orgs)
GITHUB_ORGS=marcelrapold,ZVV-Verkehrsverbund
# Comma-separated GitHub logins counted as "human" in author split (optional)
GITHUB_HUMAN_AUTHORS=

# --- Vercel API (optional, /api/infra-stats) ---
VERCEL_API_KEY=
# Comma-separated Team IDs — tracks deployments across ALL teams
VERCEL_TEAM_IDS=team_ZZpelRVLAfr8cxaPzFNOY8DC,team_lLeixJvuVuXTtChUs2G9qKUL,team_uxItE4KOo1cRkBjG3FVdkyQJ

# --- Supabase (optional, /api/infra-stats) ---
SUPABASE_ACCESS_TOKEN=
# Auto-discovers all projects if token is set. Override with JSON array:
# SUPABASE_PROJECTS=[{"id":"zwcvvbgkqhexfcldwuxq","name":"radioX.cloud"}]

# --- Health checks (optional, /api/health-check) ---
# JSON array of { name, url } — HEAD requests
# HEALTH_TARGETS=[{"name":"radioX","url":"https://radiox.cloud"},{"name":"rapold.io","url":"https://rapold.io"}]

# --- Asset generation (scripts/generate-assets.mjs) ---
APP_NAME=Cockpit
APP_DOMAIN=cockpit-muraschal.vercel.app
APP_REPO_LABEL=marcelrapold/cockpit

# --- Local dependency scan (optional) ---
# SCAN_ROOT=/path/to/parent/folder/with/cloned/repos
