# ============================================================================
# Cockpit — Environment Variables
# ============================================================================
# Copy to .env locally (never commit secrets!).
# On Vercel: Project Settings → Environment Variables.
#
# All *_TOKEN / *_KEY values are secrets — never check them into git.
# ============================================================================

# --- GitHub (required) -------------------------------------------------------
GITHUB_TOKEN=                          # Personal Access Token (repo, read:org)
GITHUB_USER=                           # Your GitHub login
GITHUB_ORGS=                           # Comma-separated org logins to track
GITHUB_HUMAN_AUTHORS=                  # Optional: logins for human/AI commit split

# --- Vercel (optional — enables infra stats) ---------------------------------
VERCEL_API_KEY=                        # Vercel account token
VERCEL_TEAM_IDS=                       # Comma-separated Team IDs

# --- Supabase (optional — enables DB health) ---------------------------------
SUPABASE_ACCESS_TOKEN=                 # Management API token
# SUPABASE_PROJECTS=[{"id":"...","name":"..."}]  # Override auto-discovery

# --- Health checks (optional) ------------------------------------------------
# HEALTH_TARGETS=[{"name":"MyApp","url":"https://example.com"}]

# --- Redis (smart caching) ---------------------------------------------------
REDIS_URL=                             # redis:// connection string (set by Vercel Redis integration)
CRON_SECRET=                           # Secret for cron endpoint auth

# --- Public API v1 (optional — /api/v1/* auth) ------------------------------
API_TOKEN=                             # Bearer token for public API access

# --- Asset generation (scripts/generate-assets.mjs) --------------------------
APP_NAME=Cockpit
APP_DOMAIN=cockpit.rapold.io
APP_REPO_LABEL=marcelrapold/cockpit

# --- Local dependency scan (optional) ----------------------------------------
# SCAN_ROOT=/path/to/repos
